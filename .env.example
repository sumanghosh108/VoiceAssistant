# Real-Time Voice Assistant Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# REQUIRED: External API Keys
# ============================================================================

WHISPER_API_KEY=""

# Google Gemini API key for language model
GEMINI_API_KEY=your-google-api-key-here
GEMINI_MODEL="liquid/lfm-2.5-1.2b-instruct:free"

# ElevenLabs API key and voice ID for text-to-speech
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=your-voice-id-here

# ============================================================================
# OPTIONAL: ASR Configuration (Wav2Vec2)
# ============================================================================

# Wav2Vec2 model name from Hugging Face (default: facebook/wav2vec2-base-960h)
# Options:
#   - facebook/wav2vec2-base-960h (default, good balance)
#   - facebook/wav2vec2-large-960h (better accuracy, slower)
#   - facebook/wav2vec2-large-960h-lv60-self (best accuracy, slowest)
# WHISPER_API_KEY=facebook/wav2vec2-base-960h

# ASR inference timeout in seconds (default: 3.0)
# WHISPER_TIMEOUT=3.0

# Gemini model name (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash

# Gemini API timeout in seconds (default: 5.0)
# GEMINI_TIMEOUT=5.0

# ElevenLabs API timeout in seconds (default: 3.0)
# ELEVENLABS_TIMEOUT=3.0

# ============================================================================
# OPTIONAL: Server Configuration
# ============================================================================

# WebSocket server host (default: 0.0.0.0)
# WEBSOCKET_HOST=0.0.0.0

# WebSocket server port (default: 8000)
# WEBSOCKET_PORT=8000

# Metrics and health check server host (default: 0.0.0.0)
# METRICS_HOST=0.0.0.0

# Metrics and health check server port (default: 8001)
# METRICS_PORT=8001

# ============================================================================
# OPTIONAL: Pipeline Configuration
# ============================================================================

# Audio buffer duration in milliseconds (default: 1000)
# AUDIO_BUFFER_MS=1000

# Token buffer size for TTS (default: 10)
# TOKEN_BUFFER_SIZE=10

# Maximum conversation turns to maintain (default: 10)
# MAX_CONVERSATION_TURNS=10

# ============================================================================
# OPTIONAL: Resilience Configuration
# ============================================================================

# Maximum retry attempts for failed API calls (default: 3)
# RETRY_MAX_ATTEMPTS=3

# Initial retry delay in milliseconds (default: 100)
# RETRY_INITIAL_DELAY_MS=100

# Maximum retry delay in milliseconds (default: 5000)
# RETRY_MAX_DELAY_MS=5000

# Circuit breaker failure threshold (0.0-1.0, default: 0.5)
# CB_FAILURE_THRESHOLD=0.5

# Circuit breaker window size in requests (default: 10)
# CB_WINDOW_SIZE=10

# Circuit breaker timeout in seconds (default: 30)
# CB_TIMEOUT_SECONDS=30

# ============================================================================
# OPTIONAL: Observability Configuration
# ============================================================================

# Enable session recording for debugging (default: false)
# ENABLE_RECORDING=false

# Path for storing session recordings (default: ./recordings)
# RECORDING_PATH=./recordings

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Latency budget for ASR in milliseconds (default: 500)
# LATENCY_BUDGET_ASR_MS=500

# Latency budget for LLM first token in milliseconds (default: 300)
# LATENCY_BUDGET_LLM_MS=300

# Latency budget for TTS in milliseconds (default: 400)
# LATENCY_BUDGET_TTS_MS=400

# Latency budget for end-to-end in milliseconds (default: 2000)
# LATENCY_BUDGET_E2E_MS=2000

# ============================================================================
# OPTIONAL: Configuration File
# ============================================================================

# Path to YAML configuration file (alternative to environment variables)
# If set, values from the file will be used as defaults, with environment
# variables taking precedence. Useful for managing complex configurations.
# CONFIG_FILE=config.yaml
